# Copy this file to `.env` (gitignored) and fill in your secrets / endpoints.
# `lighttrain` reads `.env` once at CLI startup via utils/env.load_dotenv_if_present.

# HuggingFace Hub access token (used by hf_causal model adapter and any
# transformers / datasets calls). Leave blank for public models.
HF_TOKEN=

# Mirror or self-hosted HF endpoint. Leave blank to use https://huggingface.co.
# Example for the popular hf-mirror:
# HF_ENDPOINT=https://hf-mirror.com
HF_ENDPOINT=

# Optional alias used by the huggingface_hub library.
# HF_HUB_ENDPOINT=

# Code snapshot storage policy for run provenance.
# cas is the default and stores source files once by sha256; archive writes
# a self-contained code.zip; off disables code.snapshot creation.
LIGHTTRAIN_CODE_SNAPSHOT_MODE=cas

# Optional CAS blob store location. Leave blank to use a store next to the
# current run directory's siblings.
LIGHTTRAIN_CODE_SNAPSHOT_STORE_DIR=
